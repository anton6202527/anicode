{
  "name": "anicode-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:tui": "tsx packages/tui/src/cli.tsx --demo --cwd . --sessions .anicode-dev/sessions --debug-log .anicode-dev/tui.jsonl",
    "build:cli": "npm run build --workspace anicode",
    "dev:app": "npm run dev --workspace @anicode/app",
    "build:app": "npm run build --workspace @anicode/app",
    "build:vscode": "npm run build --workspace anicode-vscode",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"*.{json,mjs}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"*.{json,mjs}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:cli && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.9.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0"
  }
}
