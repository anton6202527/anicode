{
  "name": "anicode-vscode",
  "displayName": "anicode",
  "description": "anicode —— 在 VSCode 侧边栏里与自研 coding agent 对话（复用 @anicode/core）",
  "version": "0.0.1",
  "private": true,
  "publisher": "anicode",
  "author": "anicode",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat", "Programming Languages"],
  "main": "./out/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "vsce package --no-dependencies -o anicode.vsix",
    "test": "ANICODE_LANG=zh node --import tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "activationEvents": ["onView:anicode.chat"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "anicode", "title": "anicode", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "anicode": [
        { "id": "anicode.chat", "name": "对话", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "anicode.newSession", "title": "anicode: 新对话", "icon": "$(add)" },
      { "command": "anicode.pickModel", "title": "anicode: 选择模型", "icon": "$(list-selection)" },
      { "command": "anicode.resume", "title": "anicode: 恢复会话", "icon": "$(history)" },
      { "command": "anicode.focus", "title": "anicode: 打开对话面板" }
    ],
    "menus": {
      "view/title": [
        { "command": "anicode.newSession", "when": "view == anicode.chat", "group": "navigation@1" },
        { "command": "anicode.pickModel", "when": "view == anicode.chat", "group": "navigation@2" },
        { "command": "anicode.resume", "when": "view == anicode.chat", "group": "navigation@3" }
      ]
    }
  },
  "dependencies": {
    "@anicode/core": "*",
    "@anicode/shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0"
  }
}
